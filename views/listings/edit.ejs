<% layout("/layouts/boilerplate")%>
<div class="row">
    <div class="col-8 offset-2">
        <br/><br/>
    <h3>edit ur listing</h3>
    <form method ="POST" action="/listings/<%=llisting._id %>?_method=PUT"   enctype="multipart/form-data"
novalidate class="needs-validation">

        <div>
             <label for="title" class="form-label">title</label>
<input name="listing[title]" value="<%= llisting.title%>"type="text" class="form-control" /></div>
<div class="mb-3">
  <label class="form-label">Current Image</label><br/>
  <img 
    src="<%= llisting.image.url %>" 
    style="width:200px; border-radius:10px; margin-bottom:10px;"
  />
</div>

<div class="mb-3">
  <label class="form-label">Change image (optional)</label>
  <input 
    type="file" 
    name="image" 
    class="form-control"
  />
</div>

<div>
 <label for="description" class="form-label">Description</label>
<textarea name="listing[description]"  class="form-control" required><%=llisting.description%> </textarea></div>
<div>
 <!--<label for="image" class="form-label">image</label>
<input name="listing[image]" value="<%=llisting.image%>" type="text" class="form-control"required/></div>-->
<div>
 <label for="price" class="form-label">price</label>
<input name="listing[price]" value="<%=llisting.price%>" type="number" class="form-control" required/></div>
<div>
 <label for="location" class="form-label">location</label>
<input name="listing[location]"value="<%=llisting.location%>"type="text" class="form-control"required/></div>
<div>
 <label for="country" class="form-label">country</label>   

<input name="listing[country]" placeholder="enter country"type="text" class="form-control" value="<%=llisting.country%>"   required></div>
<br/><br/>

<button class="btn btn-dark edit-btn"> edit</button>
    </form>
</div>
</div>
