<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>

    <link rel="stylesheet" href="/css/style.css"/>

    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />

    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
      integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    <!-- Rating CSS -->
    <link href="/css/rating.css" rel="stylesheet"/>

    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

    <!-- Leaflet JS in HEAD so map.js works -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

</head>

<body>

  <%- include("../includes/navbar.ejs") %>

  <div class="container mt-3">

    <% if(success && success.length > 0){ %>
      <div class="alert alert-success alert-dismissible fade show d-flex justify-content-between align-items-center shadow-sm rounded-3 px-3 py-2" role="alert">
        <span><%= success %></span>
        <button type="button" class="btn-close ms-3" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <% if(error && error.length > 0){ %>
      <div class="alert alert-danger alert-dismissible fade show d-flex justify-content-between align-items-center shadow-sm rounded-3 px-3 py-2" role="alert">
        <span><%= error %></span>
        <button type="button" class="btn-close ms-3" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <%- body %>

  </div>

  <%- include("../includes/footer.ejs") %>

  <!-- Bootstrap JS -->
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
    crossorigin="anonymous">
  </script>

  <script src="/js/script.js"></script>

</body>
</html>
